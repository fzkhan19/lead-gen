# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.


# EMAIL_USER: Your Gmail address.
EMAIL_USER=""

# EMAIL_APP_PASSWORD: Your Gmail App Password (generated in Google Account settings).
EMAIL_APP_PASSWORD=""

# GITHUB_TOKEN: Personal Access Token with 'repo' scope.
GITHUB_TOKEN=""

# GITHUB_USERNAME: Your GitHub username.
GITHUB_USERNAME=""

# GITHUB_REPO: The name of the repository for previews (defaults to business-previews).
GITHUB_REPO="business-previews"
